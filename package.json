{
  "name": "lazy-refactor",
  "version": "0.3.1",
  "description": "Claude Code plugin for deterministic code quality scanning with AI-powered fixes across TypeScript, Go, Python, C#, and Java.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Ricky Stevens",
    "url": "https://github.com/Ricky-Stevens"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ricky-Stevens/lazy-refactor.git"
  },
  "homepage": "https://github.com/Ricky-Stevens/lazy-refactor",
  "bugs": {
    "url": "https://github.com/Ricky-Stevens/lazy-refactor/issues"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "mcp",
    "code-quality",
    "refactoring",
    "linting",
    "dead-code",
    "duplicates",
    "metrics"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "main": "src/mcp/server.js",
  "scripts": {
    "test": "bun test",
    "lint": "bunx biome check src/",
    "lint:ci": "bunx biome check src/",
    "format": "bunx biome format --write src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15"
  }
}
