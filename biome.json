{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "suspicious": {
        "noAssignInExpressions": "off",
        "noTemplateCurlyInString": "off"
      }
    }
  },
  "files": {
    "includes": ["src/**/*.js"],
    "ignoreUnknown": true
  }
}
